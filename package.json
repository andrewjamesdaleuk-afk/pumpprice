{
  "name": "pumpprice-root",
  "version": "1.0.0",
  "description": "Pumpprice.live Root Management",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "cd frontend && npm install",
    "deploy": "node scripts/deploy.js",
    "dev": "npx pm2 start ecosystem.config.cjs --only pumpprice-vite",
    "prod": "npx pm2 start ecosystem.config.cjs --only pumpprice-ui",
    "restart": "npx pm2 restart ecosystem.config.cjs",
    "stop": "npx pm2 stop ecosystem.config.cjs",
    "delete": "npx pm2 delete ecosystem.config.cjs",
    "status": "npx pm2 status",
    "logs": "npx pm2 logs",
    "sitemap": "node frontend/scripts/generate_sitemap.js"
  },
  "devDependencies": {
    "pm2": "^5.3.0"
  }
}
